//tabla de multiplicar rusa
#include <iostream>
using namespace std;
int main() {
    cout << "    "; 
    for (int j = 2; j <= 9; j++) {
        cout << "  " << j;
    }
    cout <<endl;

    for (int i = 2; i <= 9; i++) {
        cout << "   " << i;

        for (int j = 2; j <= 9; j++) {
            int r = i * j;
            
            if (r < 10) {
                cout << "  " << r;
            } else {
                cout << " " << r;
            }
        }

        cout << "   " << i <<endl;
    }

    cout << "    "; 
    for (int j = 2; j <= 9; j++) {
        cout << "  " << j;
    }
    cout <<endl;

    return 0;
}